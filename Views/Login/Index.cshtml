@{
    Layout = "_LoginLayout";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card card-area shadow-lg border-0 rounded-4" style="width: 350px;">
        <div class="card-body p-4 text-center">

            <div class="bg-tertiary rounded-4 d-inline-block mb-3">
                <img src="~/Images/Logo.png" alt="Toyoda Gosei" class="img-fluid" style="max-height: 70px;" />
            </div>

            <h4 class="fw-bold mb-4"> TGRMX IT Tickets System</h4>

            <!-- Contenedor dinámico para errores AJAX -->
            <div id="loginAlert" class="alert alert-danger rounded-4 d-none"></div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger rounded-4">
                    @TempData["Error"]
                </div>
            }

            <!-- Quitamos action y añadimos un ID para procesarlo con JS -->
            <form id="formLogin">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <div class="input-group rounded-4">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <!-- Cambiado a type="number" y name="NumeroEmpleado" -->
                        <input type="number" name="NumeroEmpleado" class="form-control rounded-end" placeholder="Número de Empleado" required />
                    </div>
                </div>

                <div class="mb-3">
                    <div class="input-group rounded-4">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input type="password" name="Password" class="form-control rounded-end" placeholder="Password" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-dark w-100 rounded-pill">
                    <i class="bi bi-box-arrow-in-right"></i> Login
                </button>
            </form>

        </div>
        <div class="card-footer text-muted text-center small">
            © TGRMX Iot Department 2026
        </div>
    </div>
</div>

<!-- Lógica JavaScript para procesar el Login de forma asíncrona -->
<script>
    document.getElementById("formLogin").addEventListener("submit", function (e) {
        e.preventDefault();

        const formData = new FormData(this);
        const alertBox = document.getElementById("loginAlert");

        // Ocultar la alerta de errores previos
        alertBox.classList.add("d-none");

        fetch('/Login/Login', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Redirecciona al panel principal si las credenciales coinciden
                window.location.href = '/GestionarTickets/Index';
            } else {
                // Muestra el mensaje de error directamente en la tarjeta de login
                alertBox.textContent = data.message || "Credenciales incorrectas.";
                alertBox.classList.remove("d-none");
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alertBox.textContent = "Ocurrió un error al conectar con el servidor.";
            alertBox.classList.remove("d-none");
        });
    });
</script>
