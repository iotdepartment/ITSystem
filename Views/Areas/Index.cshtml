<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    

<div class="container-fluid mt-1">
   <div class="card mb-4 p-3 Charts-style-glass">
        <h2 class="m-0 text-start fw-bold">Gestión de Areas</h2>
   </div>
   <div class="card mb-4 p-3 style-glass">
        <div class="row mb-4 align-items-center">
            <div class="col-auto">
                <button class="btn btn-success rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#CreateAreaModal">
                    <i class="fas fa-plus"></i> Nueva Área
                </button>
            </div>
            <div class="col">
                <input type="text" id="searchInput" class="form-control rounded-pill" placeholder="Buscar area...">
            </div>
        </div>
    
        <div class="row">
            @foreach (var area in Model)
            {
                <div class="col-md-3 mb-3">
                    <div class="card card-area border" style="height: 150px;">

                        <!-- Botón de engrane -->
                        <button class="settings-btn">
                            <i class="fas fa-cog"></i>
                        </button>

                        <!-- Menú flotante -->
                        <div class="settings-menu">
                            <a href="#" class="text-dark btn-open-edit" data-id="@area.ID">
                                <i class="fas fa-edit me-2"></i>Editar
                            </a>
                            <a href="#" class="text-danger btn-open-delete" data-id="@area.ID" data-nombre="@area.Nombre">
                                <i class="fas fa-trash-alt me-2"></i>Eliminar
                            </a>
                        </div>

                        <div class="card-body">
                            <h5 class="card-title">@area.Nombre</h5>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Crear Área -->
<div class="modal card-glass fade" id="CreateAreaModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-primary">
                <h5 class="modal-title text-light">Nueva Área</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="formCreateArea">
                <div class="modal-body">

                    <div class="mb-3">
                        <label class="form-label">Nombre del Área</label>
                        <input type="text" id="NombreArea" class="form-control" required />
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-success rounded-pill">Guardar</button>
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Confirmar Eliminación de Área -->
<div class="modal card-glass fade" id="ModalEliminarArea" tabindex="-1" aria-labelledby="ModalEliminarAreaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">

            <!-- Header -->
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-bold" id="ModalEliminarAreaLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i>Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form id="formDeleteArea" method="post" action="/Areas/Delete">
                @Html.AntiForgeryToken()

                <div class="modal-body py-4">
                    <p class="fs-5 mb-1" id="deleteMessage"></p>
                    <p class="text-muted small">Esta acción no se puede deshacer.</p>
                    <input type="hidden" name="id" id="DeleteID">
                </div>
                <div class="modal-footer bg-light">
                    <button type="submit" class="btn btn-danger rounded-pill px-4" id="btnConfirmDelete">Eliminar</button>
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>

        </div>
    </div>
</div>

<!-- Modal Editar Área -->
<div class="modal card-glass fade" id="ModalEditarArea" tabindex="-1" aria-labelledby="ModalEditarAreaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">

            <!-- Header -->
            <div class="modal-header bg-warning">
                <h5 class="modal-title fw-bold" id="ModalEditarAreaLabel">
                    <i class="fas fa-edit me-2"></i>Editar Área
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- Formulario POST para actualizar -->
            <form id="formEditArea" method="post" action="/Areas/Edit">
                @Html.AntiForgeryToken() <!-- Token de seguridad indispensable -->
                <!-- Body -->
                <div class="modal-body py-4">
                    <!-- ID Oculto para indicarle al servidor qué registro actualizar -->
                    <input type="hidden" name="id" id="EditID">

                    <div class="mb-3">
                        <label for="EditNombre" class="form-label fw-bold">Nombre del Área</label>
                        <input type="text" class="form-control rounded-pill" name="nombre" id="EditNombre" required autocomplete="off">
                    </div>
                </div>

                <!-- Footer -->
                <div class="modal-footer bg-light">
                    <button type="submit" class="btn btn-warning rounded-pill px-4">Guardar Cambios</button>
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>

        </div>
    </div>
</div>



@section Scripts {
    <script>
        document.addEventListener("click", function (e) {
            const btn = e.target.closest(".settings-btn");
            const menus = document.querySelectorAll(".settings-menu");

            // Cerrar todos los menús
            menus.forEach(m => m.style.display = "none");

            // Si se hizo clic en un engrane, abrir su menú
            if (btn) {
                const menu = btn.parentElement.querySelector(".settings-menu");
                menu.style.display = "block";
                e.stopPropagation();
            }
        });
    </script>

    <script>
        document.getElementById("formCreateArea").addEventListener("submit", function (e) {
            e.preventDefault();

            const nombre = document.getElementById("NombreArea").value.trim();

            fetch("/Areas/CreateAjax", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ Nombre: nombre })
            })
            .then(res => res.json())
            .then(data => {

                if (!data.success) {
                    alert(data.message);
                    return;
                }

                // Cerrar modal
                const modal = bootstrap.Modal.getInstance(document.getElementById("CreateAreaModal"));
                modal.hide();

                // Limpiar input
                document.getElementById("NombreArea").value = "";

                // Agregar la nueva card al DOM
                agregarAreaAlDOM(data.data);

                // Notificación
                alert("Área creada correctamente");
            });
        });

        function agregarAreaAlDOM(area) {

            const contenedor = document.querySelector(".row");

            const card = document.createElement("div");
            card.classList.add("col-md-3", "mb-3");

            card.innerHTML = `
                <div class="card card-area shadow-sm border-1" style="height: 150px;">

                    <button class="settings-btn">
                        <i class="fas fa-cog"></i>
                    </button>

                    <div class="settings-menu">
                        <a href="/Areas/Edit/${area.id}">Editar</a>
                        <a href="/Areas/Delete/${area.id}" class="text-danger">Eliminar</a>
                    </div>

                    <div class="card-body">
                        <h5 class="card-title">${area.nombre}</h5>
                    </div>
                </div>
            `;

            contenedor.appendChild(card);
        }
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // ... Tu código anterior de los botones de engrane se mantiene igual ...

            // Instancia del modal de Bootstrap
            const modalEliminar = new bootstrap.Modal(document.getElementById('ModalEliminarArea'));

            // Captura el clic en cualquier enlace de eliminar
            document.querySelectorAll('.btn-open-delete').forEach(button => {
                button.addEventListener('click', function (e) {
                    e.preventDefault(); // Evita que la página navegue al '#'

                    // Cierra el menú flotante de engrane
                    this.closest('.settings-menu').classList.remove('show');

                    // Obtiene los datos del área desde los atributos data-
                    const areaId = this.getAttribute('data-id');
                    const areaNombre = this.getAttribute('data-nombre');

                    // Asigna los valores a los elementos dentro del modal
                    document.getElementById('DeleteID').value = areaId;
                    document.getElementById('deleteMessage').innerHTML = `¿Estás seguro de que deseas eliminar el área <strong>${areaNombre}</strong>?`;

                    // Si tu controlador procesa la eliminación por una URL directa (GET) tipo /Areas/Delete/5
                    // puedes cambiar dinámicamente el action del formulario descomentando la siguiente línea:
                    // document.getElementById('formDeleteArea').action = `/Areas/Delete/${areaId}`;

                    // Muestra el modal
                    modalEliminar.show();
                });
            });
        });

    </script>

    <script>
        // Instancia del modal de edición de Bootstrap
        const modalEditar = new bootstrap.Modal(document.getElementById('ModalEditarArea'));

        // Captura el clic en cualquier enlace de Editar
        document.querySelectorAll('.btn-open-edit').forEach(button => {
            button.addEventListener('click', async function (e) {
                e.preventDefault();

                // Cierra el menú de engrane flotante
                this.closest('.settings-menu').classList.remove('show');

                const areaId = this.getAttribute('data-id');

                try {
                    // Hacemos una consulta rápida al servidor para obtener los datos de esta área en formato JSON
                    const response = await fetch(`/Areas/GetArea/${areaId}`);

                    if (!response.ok) throw new Error("No se pudieron obtener los datos.");

                    const area = await response.json();

                    // Rellenamos los campos del modal de edición con la respuesta del servidor
                    document.getElementById('EditID').value = area.id; // Asegúrate de usar minúsculas/mayúsculas según devuelva tu JSON
                    document.getElementById('EditNombre').value = area.nombre;

                    // Mostramos el modal en pantalla
                    modalEditar.show();

                } catch (error) {
                    console.error(error);
                    alert("Error al cargar los datos del área.");
                }
            });
        });

    </script>
}