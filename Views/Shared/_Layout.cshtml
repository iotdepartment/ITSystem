@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ITSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Iconos de bootstrap para el menú de usuario -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ITSystem.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/Images/Logo.png" />
</head>
<body class="body-gradient">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light shadow-lg bg-secondary px-3">
            <a class="navbar-brand ms-5" href="/Tickets/Index">
                <img src="~/Images/Logo.png" alt="Logo" style="height:70px">
            </a>
            <a class="navbar-brand ms-5 fw-bold text-light" href="/Tickets/Index">TGRMX IT Tickets System</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto ms-5 mb-2 mb-lg-0">
                    <li class="nav-item ms-5"><a class="nav-link text-light" href="/Tickets/Index">Nuevo Ticket</a></li>
    
                    @{
                        // Obtenemos el rol de la sesión para usarlo en esta sección
                        var rolMenu = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioRol");
                    }

                    <!-- Estos botones solo se renderizan si el rol es Admin o Tecnico -->
                    @if (rolMenu == "Admin" || rolMenu == "Tecnico")
                    {
                        <li class="nav-item ms-5"><a class="nav-link text-light" href="/GestionarTickets/Index">Gestionar Tickets</a></li>
                        <li class="nav-item ms-5"><a class="nav-link text-light" href="/Areas/Index">Areas</a></li>
                        <li class="nav-item ms-5"><a class="nav-link text-light" href="/Usuarios/Index">Usuarios</a></li>
                        <li class="nav-item ms-5"><a class="nav-link text-light" href="/Categorias/Index">Categorias</a></li>
                    }
                    <li class="nav-item ms-5"><a class="nav-link text-light" href="#">Help</a></li>
                </ul>

                <!-- Sección del Usuario Activo -->
                <ul class="navbar-nav ms-auto me-5">
                    @{
                        var nombreUsuario = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioNombre");
                        var rolUsuario = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioRol");
                        var numEmpleado = HttpContextAccessor.HttpContext?.Session.GetInt32("UsuarioEmpleado") ?? 0;

                        // Si hay número de empleado, armamos la ruta directa: /images/Numero.jpg
                        // Si no, asignamos la imagen por defecto
                        var fotoUsuario = numEmpleado > 0
                        ? $"/Images/{numEmpleado}.jpg"
                        : "/Images/default.png";
                    }
                    @if (!string.IsNullOrEmpty(nombreUsuario))
                    {
                        <li class="nav-item dropdown">
                            <button class="nav-link dropdown-toggle text-white fw-bold bg-dark rounded-pill px-3 border-0 d-flex align-items-center" id="userDropdown" type="button" data-bs-toggle="dropdown" aria-expanded="false">

                                <!-- Busqueda directa en /images/ mediante el Número de Empleado -->
                                <img src="@fotoUsuario" alt="Perfil" class="rounded-circle me-2" style="width: 28px; height: 28px; object-fit: cover; border: 1px solid rgba(255,255,255,0.5);" />

                                <span>@nombreUsuario</span>
                                <span class="badge bg-secondary text-wrap small ms-2">@rolUsuario</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
                                <li>
                                    <a class="dropdown-item text-danger layout-logout" href="/Login/Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-light fw-bold" href="/Login/Index">Iniciar Sesión</a>
                        </li>
                    }
                </ul>



            </div>
        </nav>
    </header>

    <div class="container-fluid p-5">
        <main role="main" class="pb-0">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted text-center">
        <div class="container text-black fw-bold">
            © TGRMX Iot Department 2026
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
