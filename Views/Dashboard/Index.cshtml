<script>
    // Variable global para mantener viva la estructura de la gráfica en memoria RAM
    let chartTiemposInstancia = null;

    document.addEventListener("DOMContentLoaded", function () {
        // Carga inicial automática sin parámetros al abrir la página
        cargarGraficaTiempos();
    });

    
    function cargarGraficaTiempos(inicio = '', fin = '') {
       
        let url = '/Dashboard/ObtenerTiemposPromedio';
        if (inicio.trim() !== '' && fin.trim() !== '') {
            url += `?inicio=${inicio}&fin=${fin}`;
        }

        fetch(url)
            .then(response => {
                if (!response.ok) throw new Error("Error al obtener tiempos promedio");
                return response.json();
            })
            .then(data => {
                const ctx = document.getElementById('chartTiemposRespuesta').getContext('2d');
                if (!ctx) return;

                if (chartTiemposInstancia !== null) {
                    chartTiemposInstancia.data.datasets[0].data = data.atencion; 
                    chartTiemposInstancia.data.datasets[1].data = data.solucion; 

                    chartTiemposInstancia.update({
                        duration: 800,
                        easing: 'easeOutQuart' 
                    });
                    return; 
                }

                // BLINDAJE DE HARDWARE: Desalojo preventivo en el mapa de renderizado de Chart.js
                const graficoExistenteEnCanvas = Chart.getChart("chartTiemposRespuesta");
                if (graficoExistenteEnCanvas) {
                    graficoExistenteEnCanvas.destroy();
                }

                const meses = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];

                // CARGA INICIAL: Primera vez que se dibuja en la pantalla
                chartTiemposInstancia = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: meses,
                        datasets: [
                            {
                                label: 'Tiempo de Primera Atención (Horas)',
                                data: data.atencion,
                                borderColor: 'rgb(255, 193, 7)',
                                backgroundColor: 'rgba(255, 193, 7, 0.1)',
                                borderWidth: 3,
                                tension: 0.3,
                                fill: true,
                                yAxisID: 'yHoras'
                            },
                            {
                                label: 'Tiempo de Cierre/Solución (Días)',
                                data: data.solucion,
                                borderColor: 'rgb(13, 202, 240)',
                                backgroundColor: 'rgba(13, 202, 240, 0.1)',
                                borderWidth: 3,
                                tension: 0.3,
                                fill: true,
                                yAxisID: 'yDias'
                            }
                        ]
                    },
                    plugins: [ChartDataLabels],
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: {
                            duration: 1000 // Animación de entrada inicial
                        },
                        plugins: {
                            legend: { position: 'top' },
                            tooltip: { mode: 'index', intersect: false },
                            datalabels: {
                                anchor: 'end',
                                align: 'top',
                                offset: 4,
                                font: {
                                    weight: 'bold',
                                    size: 10,
                                    family: 'system-ui'
                                },
                                formatter: function(value, context) {
                                    if (value === 0) return ''; // Esconde ceros para no amontonar las líneas

                                    // Agrega sufijo interactivo (hrs para dataset 0, d para dataset 1)
                                    return context.datasetIndex === 0 ? value + ' hrs' : value + ' d';
                                },
                                color: function(context) {
                                    return context.dataset.borderColor;
                                }
                            }
                        },
                        scales: {
                            yHoras: {
                                type: 'linear',
                                position: 'left',
                                title: { display: true, text: 'Horas (Atención)' },
                                beginAtZero: true,
                                grid: { drawOnChartArea: true },
                                grace: '12%' // Colchón arriba para evitar que los números hrs se corten
                            },
                            yDias: {
                                type: 'linear',
                                position: 'right',
                                title: { display: true, text: 'Días (Solución)' },
                                beginAtZero: true,
                                grid: { drawOnChartArea: false },
                                grace: '12%' // Colchón arriba en el eje derecho para los números d
                            },
                            x: { grid: { display: false } }
                        }
                    }
                });
            })
            .catch(error => console.error('Error al cargar gráfica de tiempos:', error));
    }
</script>



<script>
    // Variable global para controlar la instancia del gráfico en la memoria del navegador
    let miGraficoEstados = null;

    document.addEventListener("DOMContentLoaded", function () {
        // Carga inicial por defecto al abrir el Dashboard (usa el rango anual automático)
        cargarGraficaEstadosAnual();
    });

    // Modificado: Ahora recibe los parámetros opcionales del filtro por fechas global
    function cargarGraficaEstadosAnual(inicio = '', fin = '') {
        // Construimos la URL dinámica agregando las variables de filtrado
        let url = '/Dashboard/ObtenerVolumenPorEstado';
        if (inicio.trim() !== '' && fin.trim() !== '') {
            url += `?inicio=${inicio}&fin=${fin}`;
        }

        fetch(url)
            .then(response => {
                if (!response.ok) throw new Error("Error al obtener volumen de estados");
                return response.json();
            })
            .then(data => {
                // =========================================================================
                // MODO FLUIDO: Si la gráfica YA EXISTE, mutamos sus valores internos.
                // Esto hace que las barras suban y bajen de forma elástica y sin parpadeos.
                // =========================================================================
                if (miGraficoEstados !== null) {
                    miGraficoEstados.data.datasets[0].data = data.totales;
                    miGraficoEstados.update({
                        duration: 800,
                        easing: 'easeOutQuart' // Curva de transición estilizada
                    });
                    return; // Detiene el flujo para evitar el error "Canvas is already in use"
                }

                // Si no existe la instancia física en la variable pero el Canvas está ocupado internamente, lo liberamos
                const graficoExistenteEnCanvas = Chart.getChart("chartEstadosTickets");
                if (graficoExistenteEnCanvas) {
                    graficoExistenteEnCanvas.destroy();
                }

                // Ejecuta el constructor inicial la primera vez que abre la página
                renderizarGraficaEstadosCanvas(data.estados, data.totales);
            })
            .catch(error => console.error('Error al cargar gráfica de estados:', error));
    }

    function renderizarGraficaEstadosCanvas(labels, valores) {
        const ctx = document.getElementById('chartEstadosTickets').getContext('2d');
        if (!ctx) return;

        const coloresFondo = [
            'rgba(220, 53, 69, 0.75)',  // Rojo - Por Atender
            'rgba(255, 193, 7, 0.75)',  // Amarillo - En Proceso
            'rgba(13, 202, 240, 0.75)', // Celeste - En Espera
            'rgba(25, 135, 84, 0.75)'   // Verde - Resuelto
        ];

        const coloresBorde = [
            'rgb(220, 53, 69)',
            'rgb(255, 193, 7)',
            'rgb(13, 202, 240)',
            'rgb(25, 135, 84)'
        ];

        miGraficoEstados = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    data: valores,
                    backgroundColor: coloresFondo,
                    borderColor: coloresBorde,
                    borderWidth: 1,
                    borderRadius: 6,
                    barPercentage: 0.5
                }]
            },
            plugins: [ChartDataLabels],
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: {
                    duration: 1000 // Animación de entrada inicial
                },
                plugins: {
                    legend: { display: false },
                    datalabels: {
                        anchor: 'end',
                        align: 'top',
                        offset: 2,
                        font: {
                            weight: 'bold',
                            size: 11,
                            family: 'system-ui'
                        },
                        formatter: function(value) {
                            return value > 0 ? value : '';
                        },
                        color: function(context) {
                            return coloresBorde[context.dataIndex];
                        }
                    }
                },
                scales: {
                    x: { grid: { display: false } },
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1, precision: 0 },
                        grace: '10%'
                    }
                }
            }
        });
    }
</script>



<script>
    // Variable global para mantener viva la estructura de la dona de efectividad en memoria
    let chartEfectividadInstancia = null;

    document.addEventListener("DOMContentLoaded", function () {
        // Carga inicial por defecto al abrir la página
        cargarGraficaEfectividad();
    });

    // Modificado: Ahora acepta los parámetros del rango de fechas global
    function cargarGraficaEfectividad(inicio = '', fin = '') {
        // Construimos la URL dinámica agregando las variables del filtro
        let url = `/Dashboard/ObtenerEfectividadResolucion?inicio=${inicio}&fin=${fin}`;

        fetch(url)
            .then(response => {
                if (!response.ok) throw new Error("Error al obtener datos de efectividad");
                return response.json();
            })
            .then(data => {
                // Actualizar indicador central de FCR (Primera visita) con el nuevo cálculo
                const txtFcr = document.getElementById('txtFcrPorcentaje');
                if (txtFcr) txtFcr.textContent = `${data.fcr}%`;

                const ctx = document.getElementById('chartEfectividadResolucion').getContext('2d');
                if (!ctx) return;

                if (chartEfectividadInstancia !== null) {
                    // Inyectamos las nuevas cantidades filtradas
                    chartEfectividadInstancia.data.datasets[0].data = [data.primera, data.segunda, data.extendido];

                    // Actualizamos la tooltip para que use el nuevo 'data.total' recalculado
                    chartEfectividadInstancia.options.plugins.tooltip.callbacks.label = function(context) {
                        const valor = context.raw;
                        const total = data.total;
                        const pct = total > 0 ? ((valor / total) * 100).toFixed(1) : 0;
                        return ` ${context.label}: ${valor} tickets (${pct}%)`;
                    };

                    // Disparamos la actualización progresiva elástica (duración de 800ms)
                    chartEfectividadInstancia.update({
                        duration: 800,
                        easing: 'easeOutQuart'
                    });

                    return; 
                }
 
                const graficoExistenteEnCanvas = Chart.getChart("chartEfectividadResolucion");
                if (graficoExistenteEnCanvas) {
                    graficoExistenteEnCanvas.destroy();
                }

                chartEfectividadInstancia = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Primera Visita', 'Segunda Visita', 'Tiempo Extendido'],
                        datasets: [{
                            data: [data.primera, data.segunda, data.extendido],
                            backgroundColor: [
                                'rgba(25, 135, 84, 0.85)', 
                                'rgba(13, 202, 240, 0.85)',  
                                'rgba(255, 193, 7, 0.85)'    
                            ],
                            borderColor: [
                                'rgb(25, 135, 84)',
                                'rgb(13, 202, 240)',
                                'rgb(255, 193, 7)'
                            ],
                            borderWidth: 1,
                            cutout: '75%'
                        }]
                    },
                    // PASO 1: Inyectamos el plugin para renderizar las cantidades fijas en la dona
                    plugins: [ChartDataLabels],
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: {
                            duration: 1000,
                            animateRotate: true
                        },
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    usePointStyle: true,
                                    boxWidth: 8,
                                    font: { family: 'system-ui', size: 11 }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const valor = context.raw;
                                        const total = data.total;
                                        const pct = total > 0 ? ((valor / total) * 100).toFixed(1) : 0;
                                        return ` ${context.label}: ${valor} tickets (${pct}%)`;
                                    }
                                }
                            },
                            // PASO 2: Configuración de diseño para colocar los números fijos centrados en los arcos
                            datalabels: {
                                anchor: 'center',    // Centra el número a la mitad del bloque de color
                                align: 'center',
                                font: {
                                    weight: 'bold',
                                    size: 12,
                                    family: 'system-ui'
                                },
                                // Oculta la etiqueta si la cantidad es 0 para mantener limpia la UI
                                formatter: value => value > 0 ? value : '',
                                color: function(context) {
                                    // Letra blanca para la sección verde o celeste, letra gris oscura para la sección amarilla
                                    return context.dataIndex === 2 ? '#333333' : '#ffffff';
                                }
                            }
                        }
                    }
                });
            })
            .catch(error => console.error('Error al cargar gráfica de efectividad:', error));
    }
</script>


<script>
    // Variable global para mantener viva la estructura de la gráfica apilada en memoria
    let chartCategoriasInstancia = null;

    document.addEventListener("DOMContentLoaded", function () {
        // Carga inicial por defecto al abrir la página (usa el rango anual automático)
        cargarGraficaCategoriasApilada();
    });

    // Modificado: Ahora recibe los parámetros del rango de fechas global
    function cargarGraficaCategoriasApilada(inicio = '', fin = '') {
        // Construimos la URL dinámica inyectando las variables de fecha
        let url = '/Dashboard/ObtenerResueltosPorCategoriaApilada';
        if (inicio.trim() !== '' && fin.trim() !== '') {
            url += `?inicio=${inicio}&fin=${fin}`;
        }

        fetch(url)
            .then(response => {
                if (!response.ok) throw new Error("Error al obtener datos apilados");
                return response.json();
            })
            .then(data => {
                const ctx = document.getElementById('chartCategoriasSub').getContext('2d');
                if (!ctx) return;

                // Generador dinámico de colores RGBA para que cada subcategoría tenga un color único
                const paletaColores = [
                    'rgba(25, 135, 84, 0.8)',   // Verde base
                    'rgba(13, 110, 253, 0.8)',  // Azul
                    'rgba(255, 193, 7, 0.8)',   // Amarillo
                    'rgba(13, 202, 240, 0.8)',  // Celeste
                    'rgba(111, 66, 193, 0.8)',  // Púrpura
                    'rgba(253, 126, 20, 0.8)',  // Naranja
                    'rgba(32, 201, 151, 0.8)'   // Teal
                ];

                // Inyectamos configuraciones visuales a cada conjunto de datos del backend
                const datasetsConfigurados = data.datasets.map((dataset, index) => {
                    const colorSeleccionado = paletaColores[index % paletaColores.length];
                    return {
                        label: dataset.label,
                        data: dataset.data,
                        backgroundColor: colorSeleccionado,
                        borderColor: colorSeleccionado.replace('0.8', '1'), // Color sólido para el borde
                        borderWidth: 1,
                        barPercentage: 0.6,
                        categoryPercentage: 0.7
                    };
                });

                // =========================================================================
                // MODO FLUIDO: Si la gráfica YA EXISTE, mutamos sus valores internos.
                // Re-mapeamos tanto las nuevas etiquetas del Eje X como los bloques apilados.
                // =========================================================================
                if (chartCategoriasInstancia !== null) {
                    chartCategoriasInstancia.data.labels = data.categorias;
                    chartCategoriasInstancia.data.datasets = datasetsConfigurados;

                    chartCategoriasInstancia.update({
                        duration: 800,
                        easing: 'easeOutQuart' // Curva elástica estilizada
                    });
                    return; // Detiene el flujo para evitar conflictos con el lienzo
                }

                // BLINDAJE DE HARDWARE: Nos aseguramos de desalojar cualquier render previo en el canvas
                const graficoExistenteEnCanvas = Chart.getChart("chartCategoriasSub");
                if (graficoExistenteEnCanvas) {
                    graficoExistenteEnCanvas.destroy();
                }

                // =========================================================================
                // CARGA INICIAL: Primera vez que se dibuja en la pantalla
                // =========================================================================
                chartCategoriasInstancia = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: data.categorias, // Categorías principales en el Eje X
                        datasets: datasetsConfigurados // Subcategorías apiladas
                    },
                    plugins: [ChartDataLabels],
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: {
                            duration: 1000 // Animación suave al cargar la vista
                        },
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: { usePointStyle: true, font: { family: 'system-ui', size: 11 } }
                            },
                            tooltip: { mode: 'index', intersect: false },
                            datalabels: {
                                anchor: 'center', // Centra las cantidades fijas dentro de cada bloque apilado
                                align: 'center',
                                font: { weight: 'bold', size: 10, family: 'system-ui' },
                                color: '#ffffff', // Letras blancas para excelente contraste
                                formatter: value => value > 0 ? value : '' // Esconde ceros innecesarios
                            }
                        },
                        scales: {
                            x: {
                                stacked: true,
                                grid: { display: false }
                            },
                            y: {
                                stacked: true,
                                beginAtZero: true,
                                ticks: { stepSize: 1, precision: 0 },
                                grace: '10%'
                            }
                        }
                    }
                });
            })
            .catch(error => console.error('Error al cargar gráfica apilada:', error));
    }
</script>

<script>
        document.addEventListener("DOMContentLoaded", function () {
        // 1. Establecer rango por defecto en los inputs (Enero 1 al día de hoy)
        const anioActual = new Date().getFullYear();
        const hoy = new Date().toISOString().split('T')[0];

        document.getElementById('globalFechaInicio').value = `${anioActual}-01-01`;
        document.getElementById('globalFechaFin').value = hoy;

        // Coloca el año en tus etiquetas de interfaz
        const lblAnio = document.getElementById('lblAnioActual');
        if (lblAnio) lblAnio.textContent = anioActual;

        // 2. Carga inicial de todas las gráficas
        actualizarTodoElDashboard();

        // 3. Escuchar clic del botón Aplicar Filtro
        document.getElementById('btnAplicarFiltroGlobal').addEventListener('click', function() {
            actualizarTodoElDashboard();
        });

        // 4. Escuchar clic del botón Limpiar (Regresa al año actual por defecto)
        document.getElementById('btnLimpiarFiltroGlobal').addEventListener('click', function() {
            document.getElementById('globalFechaInicio').value = `${anioActual}-01-01`;
            document.getElementById('globalFechaFin').value = hoy;
            actualizarTodoElDashboard();
        });
    });

    // FUNCIÓN MAESTRA DE CONEXIÓN
    function actualizarTodoElDashboard() {
        const inicio = document.getElementById('globalFechaInicio').value;
        const fin = document.getElementById('globalFechaFin').value;

        // Valida que si se ingresó una fecha, se ingresen ambas
        if ((inicio && !fin) || (!inicio && fin)) {
            alert("Por favor, selecciona un rango de fechas completo (Desde y Hasta).");
            return;
        }

        // Pasamos los parámetros de manera unificada a todas tus funciones existentes
        cargarGraficaTickets(inicio, fin);          // Creados vs Cerrados
        cargarGraficaCumplimiento(inicio, fin);     // Porcentaje de cumplimiento
        cargarGraficaPorTecnico(inicio, fin);       // Carga por Técnico
        cargarGraficaTiempos(inicio, fin);          // Tiempos promedio de respuesta
        cargarGraficaEfectividad(inicio, fin); 
        cargarGraficaEstadosAnual(inicio, fin);     // Distribución por Estado
        cargarGraficaCategoriasApilada(inicio, fin); // Categorías y subcategorías apiladas
    }

</script>

