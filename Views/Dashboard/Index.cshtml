<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels"></script>

<script>
       // Variable de respaldo global
    let chartAnualInstancia = null;

    function cargarGraficaTickets(inicio = '', fin = '') {
        let url = `/Dashboard/ObtenerMetricasAnuales?inicio=${inicio}&fin=${fin}`;

        fetch(url)
            .then(response => response.json())
            .then(data => {
                const canvasElement = document.getElementById('chartTicketsAnual');
                if (!canvasElement) return;

                const ctx = canvasElement.getContext('2d');
                const graficoExistenteEnCanvas = Chart.getChart("chartTicketsAnual");
                if (graficoExistenteEnCanvas) {
                    graficoExistenteEnCanvas.destroy();
                }

                // Reiniciamos nuestra variable de control por seguridad
                if (chartAnualInstancia !== null) {
                    try { chartAnualInstancia.destroy(); } catch(e) {}
                    chartAnualInstancia = null;
                }

                const meses = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];

                // Creamos la instancia limpiamente sobre el lienzo garantizado desocupado
                chartAnualInstancia = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: meses,
                        datasets: [
                            {
                                label: 'Tickets Generados',
                                data: data.creados,
                                backgroundColor: 'rgba(13, 110, 253, 0.75)',
                                borderColor: 'rgb(13, 110, 253)',
                                borderWidth: 1,
                                borderRadius: 6,
                                barPercentage: 0.8,
                                categoryPercentage: 0.7
                            },
                            {
                                label: 'Tickets Cerrados',
                                data: data.cerrados,
                                backgroundColor: 'rgba(25, 135, 84, 0.75)',
                                borderColor: 'rgb(25, 135, 84)',
                                borderWidth: 1,
                                borderRadius: 6,
                                barPercentage: 0.8,
                                categoryPercentage: 0.7
                            }
                        ]
                    },
                    plugins: [ChartDataLabels],
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'top',
                                labels: { usePointStyle: true, boxWidth: 10, font: { weight: 'bold', family: 'system-ui' } }
                            },
                            tooltip: { mode: 'index', intersect: false, padding: 12 },
                            datalabels: {
                                anchor: 'end',
                                align: 'top',
                                offset: 2,
                                font: { weight: 'bold', size: 11, family: 'system-ui' },
                                formatter: value => value > 0 ? value : '',
                                color: context => context.dataset.borderColor
                            }
                        },
                        scales: {
                            x: { grid: { display: false } },
                            y: { beginAtZero: true, ticks: { stepSize: 1, precision: 0 }, grace: '10%' }
                        }
                    }
                });
            })
            .catch(error => console.error('Error al cargar la gráfica del dashboard:', error));
    }

</script>

<script>
    // Variable global que mantendrá viva la estructura base de la gráfica en la memoria del navegador
    let chartCumplimientoInstancia = null;

    function cargarGraficaCumplimiento(inicio = '', fin = '') {
        // Construimos la URL agregando las variables del filtro global
        let url = `/Dashboard/ObtenerPorcentajeCumplimiento?inicio=${inicio}&fin=${fin}`;

        fetch(url)
            .then(response => {
                if (!response.ok) throw new Error("Error al obtener métricas de cumplimiento");
                return response.json();
            })
            .then(data => {
                // 1. Actualizar el texto numérico grande debajo de la dona
                const txtPorcentaje = document.getElementById('txtPorcentajeGranTotal');
                if (txtPorcentaje) txtPorcentaje.textContent = `${data.porcentajeCumplimiento}%`;

                const ctx = document.getElementById('chartCumplimiento').getContext('2d');
                if (!ctx) return;
                if (chartCumplimientoInstancia !== null) {
                    // Reemplazamos los valores viejos por los nuevos datos filtrados
                    chartCumplimientoInstancia.data.datasets[0].data = [data.resueltos, data.pendientes];

                    // Actualizamos la tooltip para que use el nuevo 'data.total' recalculado
                    chartCumplimientoInstancia.options.plugins.tooltip.callbacks.label = function(context) {
                        const valor = context.raw;
                        const total = data.total;
                        const pct = total > 0 ? ((valor / total) * 100).toFixed(1) : 0;
                        return ` ${context.label}: ${valor} tickets (${pct}%)`;
                    };

                    chartCumplimientoInstancia.update({
                        duration: 800,
                        easing: 'easeOutQuart'
                    });

                    return; 
                }
                chartCumplimientoInstancia = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Resueltos', 'Pendientes / Otros'],
                        datasets: [{
                            data: [data.resueltos, data.pendientes],
                            backgroundColor: [
                                'rgba(25, 135, 84, 0.85)',  
                                'rgba(220, 53, 69, 0.15)'   
                            ],
                            borderColor: [
                                'rgb(25, 135, 84)',
                                'rgba(220, 53, 69, 0.4)'
                            ],
                            borderWidth: 1,
                            cutout: '75%'
                        }]
                    },
                    plugins: [ChartDataLabels],
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        // Configuración de la animación inicial de entrada
                        animation: {
                            duration: 1000,
                            animateRotate: true,
                            animateScale: false
                        },
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    usePointStyle: true,
                                    boxWidth: 8,
                                    font: { family: 'system-ui', size: 12 }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const valor = context.raw;
                                        const total = data.total;
                                        const pct = total > 0 ? ((valor / total) * 100).toFixed(1) : 0;
                                        return ` ${context.label}: ${valor} tickets (${pct}%)`;
                                    }
                                }
                            },
                            datalabels: {
                                anchor: 'center',
                                align: 'center',
                                font: {
                                    weight: 'bold',
                                    size: 13,
                                    family: 'system-ui'
                                },
                                formatter: function(value) {
                                    return value > 0 ? value : '';
                                },
                                color: function(context) {
                                    return context.dataIndex === 0 ? '#ffffff' : 'rgb(220, 53, 69)';
                                }
                            }
                        }
                    }
                });
            })
            .catch(error => console.error('Error al cargar gráfica de cumplimiento filtrada:', error));
    }
</script>



<script>
    // Variable global de respaldo para el control de la gráfica de técnicos
    let chartTecnicosInstancia = null;

    document.addEventListener("DOMContentLoaded", function () {
        const lblAnio = document.getElementById('lblAnioActual');
        if (lblAnio) lblAnio.textContent = new Date().getFullYear();

        // Carga inicial sin parámetros (tomará los valores por defecto)
        cargarGraficaPorTecnico();
    });

    // Modificado: Ahora recibe los parámetros opcionales del rango global de fechas
    function cargarGraficaPorTecnico(inicio = '', fin = '') {
        // Construimos la URL dinámica inyectando las variables de fecha
        let url = `/Dashboard/ObtenerTicketsPorTecnico?inicio=${inicio}&fin=${fin}`;

        fetch(url)
            .then(response => {
                if (!response.ok) throw new Error("Error al obtener carga detallada por técnico");
                return response.json();
            })
            .then(data => {
                const canvasElement = document.getElementById('chartTicketsPorTecnico');
                if (!canvasElement) return;

                const ctx = canvasElement.getContext('2d');

                const graficoExistenteEnCanvas = Chart.getChart("chartTicketsPorTecnico");
                if (graficoExistenteEnCanvas) {
                    graficoExistenteEnCanvas.destroy(); // Desaloja y limpia el hardware de inmediato
                }

                // Limpieza preventiva de nuestra variable de control
                if (chartTecnicosInstancia !== null) {
                    try { chartTecnicosInstancia.destroy(); } catch(e) {}
                    chartTecnicosInstancia = null;
                }

                // Construimos la gráfica sobre el canvas garantizado desocupado
