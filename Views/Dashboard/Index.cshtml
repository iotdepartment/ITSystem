<script>
    let chartTiemposInstancia = null;

    document.addEventListener("DOMContentLoaded", function () {
        cargarGraficaTiempos();
    });

    function cargarGraficaTiempos() {
        fetch('/Dashboard/ObtenerTiemposPromedio')
            .then(response => {
                if (!response.ok) throw new Error("Error al obtener tiempos promedio");
                return response.json();
            })
            .then(data => {
                const ctx = document.getElementById('chartTiemposRespuesta').getContext('2d');
                if (!ctx) return;

               
                if (chartTiemposInstancia !== null) {
                    chartTiemposInstancia.destroy();
                }

                const meses = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];

             
                chartTiemposInstancia = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: meses,
                        datasets: [
                            {
                                label: 'Tiempo de Primera Atención (Horas)',
                                data: data.atencion,
                                borderColor: 'rgb(255, 193, 7)',
                                backgroundColor: 'rgba(255, 193, 7, 0.1)',
                                borderWidth: 3,
                                tension: 0.3,
                                fill: true,
                                yAxisID: 'yHoras'
                            },
                            {
                                label: 'Tiempo de Cierre/Solución (Días)',
                                data: data.solucion,
                                borderColor: 'rgb(13, 202, 240)',
                                backgroundColor: 'rgba(13, 202, 240, 0.1)',
                                borderWidth: 3,
                                tension: 0.3,
                                fill: true,
                                yAxisID: 'yDias'
                            }
                        ]
                    },
                    
                    plugins: [ChartDataLabels],
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { position: 'top' },
                            tooltip: { mode: 'index', intersect: false },
                       
                            datalabels: {
                                anchor: 'end',       
                                align: 'top',      
                                offset: 4,           
                                font: {
                                    weight: 'bold',
                                    size: 10,
                                    family: 'system-ui'
                                },
                               
                                formatter: function(value, context) {
                                    if (value === 0) return '';

                                 
                                    return context.datasetIndex === 0 ? value + ' hrs' : value + ' d';
                                },
       
                                color: function(context) {
                                    return context.dataset.borderColor;
                                }
                            }
                        },
                        scales: {
                            yHoras: {
                                type: 'linear',
                                position: 'left',
                                title: { display: true, text: 'Horas (Atención)' },
                                beginAtZero: true,
                                grid: { drawOnChartArea: true },
                                grace: '12%' 
                            },
                            yDias: {
                                type: 'linear',
                                position: 'right',
                                title: { display: true, text: 'Días (Solución)' },
                                beginAtZero: true,
                                grid: { drawOnChartArea: false },
                                grace: '12%'
                            },
                            x: { grid: { display: false } }
                        }
                    }
                });
            })
            .catch(error => console.error('Error al cargar gráfica de tiempos:', error));
    }
</script>


<script>
    // Variable para controlar la instancia del gráfico en la memoria del navegador
    let miGraficoEstados = null;

    document.addEventListener("DOMContentLoaded", function () {
        // Carga el volumen anual de inmediato
        cargarGraficaEstadosAnual();
    });

    function cargarGraficaEstadosAnual() {
        fetch('/Dashboard/ObtenerVolumenPorEstado')
            .then(response => {
                if (!response.ok) throw new Error("Error al obtener volumen anual de estados");
                return response.json();
            })
            .then(data => {
                renderizarGraficaEstadosCanvas(data.estados, data.totales);
            })
            .catch(error => console.error('Error al cargar gráfica de estados:', error));
    }

    function renderizarGraficaEstadosCanvas(labels, valores) {
        const ctx = document.getElementById('chartEstadosTickets').getContext('2d');
        if (!ctx) return;

        // Limpieza de caché gráfica previa para evitar duplicación de texto
        if (miGraficoEstados !== null) {
            miGraficoEstados.destroy();
        }

        const coloresFondo = [
            'rgba(220, 53, 69, 0.75)',  // Rojo - Por Atender
            'rgba(255, 193, 7, 0.75)',  // Amarillo - En Proceso
            'rgba(13, 202, 240, 0.75)', // Celeste - En Espera
            'rgba(25, 135, 84, 0.75)'   // Verde - Resuelto
        ];

        const coloresBorde = [
            'rgb(220, 53, 69)',
            'rgb(255, 193, 7)',
            'rgb(13, 202, 240)',
            'rgb(25, 135, 84)'
        ];

        miGraficoEstados = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    data: valores,
                    backgroundColor: coloresFondo,
                    borderColor: coloresBorde,
                    borderWidth: 1,
                    borderRadius: 6,
                    barPercentage: 0.5
                }]
            },
            plugins: [ChartDataLabels],
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    datalabels: {
                        anchor: 'end',
                        align: 'top',
                        offset: 2,
                        font: {
                            weight: 'bold',
                            size: 11,
                            family: 'system-ui'
                        },
                        formatter: function(value) {
                            return value > 0 ? value : '';
                        },
                        color: function(context) {
                            return coloresBorde[context.dataIndex];
                        }
                    }
                },
                scales: {
                    x: { grid: { display: false } },
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1, precision: 0 },
                        grace: '10%' // Añade espacio arriba para que el número anual más alto no se corte
                    }
                }
            }
        });
    }
</script>


