<script>
    let chartCategoriasInstancia = null;

    document.addEventListener("DOMContentLoaded", function () {
        cargarGraficaCategoriasApilada();
    });

    function cargarGraficaCategoriasApilada() {
        // Apuntamos al nuevo endpoint de barras apiladas
        fetch('/Dashboard/ObtenerResueltosPorCategoriaApilada')
            .then(response => {
                if (!response.ok) throw new Error("Error al obtener datos apilados");
                return response.json();
            })
            .then(data => {
                const ctx = document.getElementById('chartCategoriasSub').getContext('2d');
                if (!ctx) return;

                if (chartCategoriasInstancia !== null) {
                    chartCategoriasInstancia.destroy();
                }

                // Generador dinámico de colores RGBA para que cada subcategoría tenga un color único
                const paletaColores = [
                    'rgba(25, 135, 84, 0.8)',   // Verde base
                    'rgba(13, 110, 253, 0.8)',  // Azul
                    'rgba(255, 193, 7, 0.8)',   // Amarillo
                    'rgba(13, 202, 240, 0.8)',  // Celeste
                    'rgba(111, 66, 193, 0.8)',  // Púrpura
                    'rgba(253, 126, 20, 0.8)',  // Naranja
                    'rgba(32, 201, 151, 0.8)'   // Teal
                ];

                // Inyectamos configuraciones visuales a cada conjunto de datos del backend
                const datasetsConfigurados = data.datasets.map((dataset, index) => {
                    const colorSeleccionado = paletaColores[index % paletaColores.length];
                    return {
                        label: dataset.label,
                        data: dataset.data,
                        backgroundColor: colorSeleccionado,
                        borderColor: colorSeleccionado.replace('0.8', '1'), // Color sólido para el borde
                        borderWidth: 1,
                        barPercentage: 0.6,
                        categoryPercentage: 0.7
                    };
                });

                chartCategoriasInstancia = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: data.categorias, // Categorías principales en el Eje X
                        datasets: datasetsConfigurados // Subcategorías apiladas
                    },
                    plugins: [ChartDataLabels],
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom', // Mostramos la leyenda abajo para identificar las subcategorías
                                labels: { usePointStyle: true, font: { family: 'system-ui', size: 11 } }
                            },
                            tooltip: { mode: 'index', intersect: false },
                            datalabels: {
                                anchor: 'center', // Centra la cantidad fija dentro de cada bloque apilado
                                align: 'center',
                                font: { weight: 'bold', size: 10, family: 'system-ui' },
                                color: '#ffffff', // Letras blancas para contrastar con las barras
                                formatter: value => value > 0 ? value : '' // Oculta ceros
                            }
                        },
                        scales: {
                            // CLAVE: Activamos 'stacked: true' en ambos ejes para habilitar el apilamiento
                            x: {
                                stacked: true,
                                grid: { display: false }
                            },
                            y: {
                                stacked: true,
                                beginAtZero: true,
                                ticks: { stepSize: 1, precision: 0 },
                                grace: '10%'
                            }
                        }
                    }
                });
            })
            .catch(error => console.error('Error al cargar gráfica apilada:', error));
    }
</script>

