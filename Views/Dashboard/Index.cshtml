<!-- SECCIÓN DE GRÁFICAS DEL DASHBOARD -->
<div class="container-fluid">
    <div class="card mb-4 p-3 border Charts-style-glass">
        <h2 class="m-0 text-start fw-bold">Graficas de Rendimiento</h2>
    </div>
    <div class="row mb-4">
        <div class="col-9">
            <div class="card Charts-style-glass h-100">
                <div class="card-header py-3 d-flex align-items-center justify-content-between">
                    <h5 class="card-title mb-0 fw-bold text-dark">
                        <i class="fas fa-chart-bar me-2 text-primary"></i>Rendimiento Anual: Creados vs Cerrados
                    </h5>
                    <span class="badge bg-light text-dark fw-semibold px-3 py-2 rounded-pill border">
                        Año <span id="lblAnioActual"></span>
                    </span>
                </div>
                <div class="card-body p-4">
                    <div style="position: relative; height: 320px; width: 100%;">
                        <!-- El lienzo donde Chart.js pintará la gráfica -->
                        <canvas id="chartTicketsAnual"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <!-- Gráfica de Cumplimiento (Derecha) -->
        <div class="col-3">
            <div class="card Charts-style-glass h-100">
                <div class="card-header py-3">
                    <h5 class="card-title mb-0 fw-bold text-dark">
                        <i class="fas fa-chart-pie me-2 text-success"></i>Porcentaje de Cumplimiento
                    </h5>
                </div>
                <div class="card-body p-4 d-flex flex-column align-items-center justify-content-center position-relative">
                    <div style="position: relative; height: 260px; width: 100%;">
                        <canvas id="chartCumplimiento"></canvas>
                    </div>
                    <!-- Texto central con el porcentaje grande -->
                    <div class="text-center mt-3">
                        <h3 class="fw-bold text-dark mb-0" id="txtPorcentajeGranTotal">0%</h3>
                        <small class="text-muted">Tickets Resueltos con éxito</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card Charts-style-glass h-100">
                <div class="card-header py-3 d-flex align-items-center justify-content-between">
                    <h5 class="card-title mb-0 fw-bold text-dark">
                        <i class="fas fa-user-tie me-2 text-info"></i>Carga de Trabajo: Tickets Activos por Técnico
                    </h5>
                    <span class="badge bg-light text-muted fw-normal px-3 py-2 rounded-pill border">
                        Métricas del año en curso
                    </span>
                </div>
                <div class="card-body p-4">
                    <div style="position: relative; height: 350px; width: 100%;">
                        <canvas id="chartTicketsPorTecnico"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-9">
            <div class="card Charts-style-glass h-100">
                <div class="card-header py-3 d-flex align-items-center justify-content-between">
                    <h5 class="card-title mb-0 fw-bold text-dark">
                        <i class="fas fa-hourglass-half me-2 text-warning"></i>Tiempos Promedio de Respuesta y Solución
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div style="position: relative; height: 320px; width: 100%;">
                        <canvas id="chartTiemposRespuesta"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- GRÁFICA DE EFECTIVIDAD DE RESOLUCIÓN -->
        <div class="col-3">
            <div class="card Charts-style-glass h-100">
                <div class="card-header py-3">
                    <h5 class="card-title mb-0 fw-bold text-dark">
                        <i class="fas fa-bullseye me-2 text-primary"></i>Efectividad de Resolución
                    </h5>
                </div>
                <div class="card-body p-4 d-flex flex-column align-items-center justify-content-center">
                    <div style="position: relative; height: 260px; width: 100%;">
                        <canvas id="chartEfectividadResolucion"></canvas>
                    </div>
                    <div class="text-center mt-3">
                        <h3 class="fw-bold text-dark mb-0" id="txtFcrPorcentaje">0%</h3>
                        <small class="text-muted">Resolución en Primer Contacto</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card Charts-style-glass">
                <!-- Encabezado Limpio -->
                <div class="card-header py-3 d-flex align-items-center justify-content-between">
                    <h5 class="card-title mb-0 fw-bold text-dark">
                        <i class="fas fa-tasks me-2 text-primary"></i>Distribución de Tickets por Estado Actual
                    </h5>
                    <span class="badge bg-light text-muted fw-normal px-3 py-2 rounded-pill border">
                        Métricas del año en curso
                    </span>
                </div>

                <div class="card-body p-4">
                    <div style="position: relative; height: 300px; width: 100%;">
                        <canvas id="chartEstadosTickets"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    
    <!-- GRÁFICA DE TICKETS RESUELTOS POR CATEGORÍA Y SUBCATEGORÍA -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card Charts-style-glass">
                <div class="card-header py-3">
                    <h5 class="card-title mb-0 fw-bold text-dark">
                        <i class="fas fa-tags me-2 text-success"></i>Efectividad por Servicio: Resueltos por Categoría / Subcategoría
                    </h5>
                </div>
                <div class="card-body p-4">
                    <!-- Se asigna una altura cómoda de 350px para ver las barras con espacio -->
                    <div style="position: relative; height: 350px; width: 100%;">
                        <canvas id="chartCategoriasSub"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Asegúrate de incluir la librería Chart.js si no la tienes en tu Layout -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const lblAnio = document.getElementById('lblAnioActual');
        if (lblAnio) lblAnio.textContent = new Date().getFullYear();

  
        cargarGraficaTickets();
    });

    function cargarGraficaTickets() {
        fetch('/Dashboard/ObtenerMetricasAnuales')
            .then(response => response.json())
            .then(data => {
                const ctx = document.getElementById('chartTicketsAnual').getContext('2d')

                const meses = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];

                new Chart(ctx, {
                    type: 'bar', 
                    data: {
                        labels: meses,
                        datasets: [
                            {
                                label: 'Tickets Generados',
                                data: data.creados,
                                backgroundColor: 'rgba(13, 110, 253, 0.75)', 
                                borderColor: 'rgb(13, 110, 253)',
                                borderWidth: 1,
                                borderRadius: 6,
                                barPercentage: 0.8,
                                categoryPercentage: 0.7
                            },
                            {
                                label: 'Tickets Cerrados',
                                data: data.cerrados,
                                backgroundColor: 'rgba(25, 135, 84, 0.75)', 
                                borderColor: 'rgb(25, 135, 84)',
                                borderWidth: 1,
                                borderRadius: 6,
                                barPercentage: 0.8,
                                categoryPercentage: 0.7
                            }
                        ]
                    },

                    plugins: [ChartDataLabels],
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'top',
                                labels: {
                                    usePointStyle: true,
                                    boxWidth: 10,
                                    font: { weight: 'bold', family: 'system-ui' }
                                }
                            },
                            tooltip: {
                                mode: 'index',
                                intersect: false,
                                padding: 12
                            },
                     
                            datalabels: {
                                anchor: 'end',      
                                align: 'top',       
                                offset: 2,           
                                font: {
                                    weight: 'bold',
                                    size: 11,
                                    family: 'system-ui'
                                },
                        
                                formatter: function(value) {
                                    return value > 0 ? value : '';
                                },
                        
                                color: function(context) {
                                    return context.dataset.borderColor;
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: { display: false } 
                            },
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    stepSize: 1,
                                    precision: 0
                                },
                                grace: '10%' 
                            }
                        }
                    }
                });
            })
            .catch(error => console.error('Error al cargar la gráfica del dashboard:', error));
    }
</script>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const lblAnio = document.getElementById('lblAnioActual');
        if (lblAnio) lblAnio.textContent = new Date().getFullYear();
        cargarGraficaCumplimiento();
    });

    function cargarGraficaCumplimiento() {
        fetch('/Dashboard/ObtenerPorcentajeCumplimiento')
            .then(response => {
                if (!response.ok) throw new Error("Error al obtener métricas de cumplimiento");
                return response.json();
            })
            .then(data => {
                const txtPorcentaje = document.getElementById('txtPorcentajeGranTotal');
                if (txtPorcentaje) txtPorcentaje.textContent = `${data.porcentajeCumplimiento}%`;

                const ctx = document.getElementById('chartCumplimiento').getContext('2d');
                if (!ctx) return;

                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Resueltos', 'Pendientes / Otros'],
                        datasets: [{
                            data: [data.resueltos, data.pendientes],
                            backgroundColor: [
                                'rgba(25, 135, 84, 0.85)',  
                                'rgba(220, 53, 69, 0.15)'  
                            ],
                            borderColor: [
                                'rgb(25, 135, 84)',
                                'rgba(220, 53, 69, 0.4)'
                            ],
                            borderWidth: 1,
                            cutout: '75%' 
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    usePointStyle: true,
                                    boxWidth: 8,
                                    font: { family: 'system-ui', size: 12 }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const valor = context.raw;
                                        const total = data.total;
                                        const pct = total > 0 ? ((valor / total) * 100).toFixed(1) : 0;
                                        return ` ${context.label}: ${valor} tickets (${pct}%)`;
                                    }
                                }
                            }
                        }
                    }
                });
            })
            .catch(error => console.error('Error al cargar gráfica de cumplimiento:', error));
    }
</script>

