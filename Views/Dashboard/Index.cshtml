                                borderRadius: 4,
                                barPercentage: 0.8,
                                categoryPercentage: 0.6
                            }
                        ]
                    },
                    plugins: [ChartDataLabels],
                    options: {
                        indexAxis: 'y', 
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'top',
                                labels: {
                                    usePointStyle: true,
                                    boxWidth: 10,
                                    font: { family: 'system-ui', weight: 'bold' }
                                }
                            },
